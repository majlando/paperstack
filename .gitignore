# Dependencies / build output
node_modules/
dist/
target/

# Dev binaries (typst, pandoc) — fetched by scripts/fetch-binaries.ts
bin/

# Tauri
src-tauri/target/

# Build output of report projects (incl. fixtures) — never commit built PDFs
output/

# The builder vendors the template into a project on first build. Real
# projects commit theirs; the fixtures must not — a committed copy would
# shadow SEA_TEMPLATE and template.ts changes would stop being tested.
/fixtures/demo-report/paperstack-template.typ
/fixtures/showcase-report/paperstack-template.typ

# The author's actual SEA report (separate private repo, used as a local
# test fixture only — contains personal exam content, never committed here)
report/
report-migrated/

# Editor / OS noise
.idea/
.vscode/
Thumbs.db
.DS_Store

# Claude Code session state (worktrees hold node_modules copies)
.claude/

# Logs
*.log
