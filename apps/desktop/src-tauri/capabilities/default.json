{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Main window. No static fs/asset scope: project folders are granted at runtime via the allow_project_scope command when the user opens them.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-exists",
    "fs:allow-read-dir",
    "fs:allow-mkdir",
    "fs:allow-rename",
    "fs:allow-remove",
    "fs:allow-copy-file",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "binaries/typst", "sidecar": true, "args": true },
        { "name": "binaries/pandoc", "sidecar": true, "args": true }
      ]
    }
  ]
}
